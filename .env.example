# JobTrack AI — Environment Variables
# Copy this file to .env and fill in your values

# Django Security
SECRET_KEY=your-secret-key-here
DEBUG=False  # Always set to False in production
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:5173

# PostgreSQL Database
DB_NAME=jobtrack
DB_USER=jobtrack
DB_PASSWORD=jobtrack
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google Cloud / Vertex AI
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GEMINI_API_KEY=your-gemini-api-key

# Google Calendar OAuth 2.0 (one-time per-user consent)
GOOGLE_CALENDAR_CLIENT_ID=your-calendar-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-calendar-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/calendar/callback/

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000

# Email Configuration (backend auto-selects SMTP if credentials are set, otherwise uses console)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
